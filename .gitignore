# ═══════════════════════════════════════════════════
# LogAnalyzer Pro - .gitignore
# ═══════════════════════════════════════════════════

# ───────────────────────────────────────────────────
# Python
# ───────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# ───────────────────────────────────────────────────
# Environnements virtuels
# ───────────────────────────────────────────────────
venv/
ENV/
env/
.venv/

# ───────────────────────────────────────────────────
# IDE et Éditeurs
# ───────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
.project
.pydevproject
.settings/

# ───────────────────────────────────────────────────
# Système d'exploitation
# ───────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db

# ───────────────────────────────────────────────────
# Logs et Rapports générés (À IGNORER)
# ───────────────────────────────────────────────────
backups/
*.log
logs_test/
rapport_*.json
backup_*.tar.gz

# ───────────────────────────────────────────────────
# Fichiers de test temporaires
# ───────────────────────────────────────────────────
test.txt
*.tmp
*.temp

# ───────────────────────────────────────────────────
# Git
# ───────────────────────────────────────────────────
.gitignore~


# ───────────────────────────────────────────────────
# Autre
# ───────────────────────────────────────────────────

test.txt
lscat.sh
backups/*.json